<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI News — {{ generated_at }}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0f1117;
      --surface: #1a1d27;
      --border: #2a2d3a;
      --text: #e8e9ed;
      --muted: #8b8fa8;
      --accent: #6366f1;
      --accent-soft: #312e81;
      --green: #22c55e;
      --amber: #f59e0b;
      --red: #ef4444;
      --tag-bg: #1e2133;
      --radius: 10px;
      --shadow: 0 2px 8px rgba(0,0,0,.4);
    }

    body {
      font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
      min-height: 100vh;
    }

    .wrapper { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem 4rem; }

    header {
      padding: 2rem 1.5rem 1.5rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .site-title { font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; }
    .site-title span { color: var(--accent); }
    .meta { font-size: 0.8rem; color: var(--muted); }

    .search-bar {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 0.4rem 0.75rem;
      width: 100%;
      max-width: 360px;
    }
    .search-bar input {
      border: none;
      background: transparent;
      color: var(--text);
      font-size: 0.9rem;
      outline: none;
      width: 100%;
    }
    .search-bar input::placeholder { color: var(--muted); }

    .section { margin-bottom: 3rem; }
    .section-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1.25rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--border);
    }
    .section-title { font-size: 1.1rem; font-weight: 600; }
    .section-count {
      font-size: 0.75rem;
      background: var(--tag-bg);
      color: var(--muted);
      padding: 0.1rem 0.5rem;
      border-radius: 999px;
    }

    .cards-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 1rem;
    }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      max-height: 600px;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .card:hover { border-color: var(--accent); box-shadow: var(--shadow); }

    .card-image {
      width: 100%;
      aspect-ratio: 16/9;
      object-fit: cover;
      display: block;
      background: var(--border);
    }

    .card-body { padding: 1rem; flex: 1; display: flex; flex-direction: column; gap: 0.5rem; }

    .card-meta {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      flex-wrap: wrap;
      font-size: 0.72rem;
    }

    .badge {
      padding: 0.15rem 0.5rem;
      border-radius: 999px;
      font-weight: 600;
      font-size: 0.68rem;
      letter-spacing: 0.02em;
      white-space: nowrap;
    }
    .badge-source { background: var(--accent-soft); color: #a5b4fc; }
    .badge-topic  { background: #1a2e1a; color: #86efac; }
    .badge-top    { background: #3b1e06; color: #fbbf24; }

    .card-date { color: var(--muted); }

    .card-title {
      font-size: 0.95rem;
      font-weight: 600;
      line-height: 1.35;
    }
    .card-title a { color: var(--text); text-decoration: none; }
    .card-title a:hover { color: var(--accent); }

    .card-annotation { font-size: 0.82rem; color: var(--muted); line-height: 1.55; }
    .card-why { font-size: 0.78rem; color: #86efac; font-style: italic; }

    .card-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.3rem;
      margin-top: auto;
      padding-top: 0.4rem;
    }
    .tag {
      font-size: 0.68rem;
      background: var(--tag-bg);
      color: var(--muted);
      padding: 0.1rem 0.45rem;
      border-radius: 4px;
    }

    .card-footer {
      padding: 0.6rem 1rem;
      border-top: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.5rem;
    }
    .card-link {
      font-size: 0.75rem;
      color: var(--accent);
      text-decoration: none;
      font-weight: 500;
    }
    .card-link:hover { text-decoration: underline; }

    .score { font-size: 0.7rem; color: var(--muted); }
    .score-high { color: var(--green); }
    .score-mid  { color: var(--amber); }
    .score-low  { color: var(--muted); }

    .source-group { margin-bottom: 1.5rem; }
    .source-group-title { font-size: 0.85rem; font-weight: 600; color: var(--muted); margin-bottom: 0.5rem; }
    .source-list { list-style: none; }
    .source-list li {
      padding: 0.4rem 0;
      border-bottom: 1px solid var(--border);
      font-size: 0.85rem;
      display: flex;
      align-items: flex-start;
      gap: 0.6rem;
    }
    .source-list li:last-child { border-bottom: none; }
    .source-list a { color: var(--text); text-decoration: none; }
    .source-list a:hover { color: var(--accent); }
    .source-date { color: var(--muted); font-size: 0.72rem; flex-shrink: 0; }

    .image-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 0.75rem;
    }
    .img-card {
      position: relative;
      border-radius: var(--radius);
      overflow: hidden;
      background: var(--surface);
      border: 1px solid var(--border);
    }
    .img-card img {
      width: 100%;
      aspect-ratio: 16/9;
      object-fit: cover;
      display: block;
    }
    .img-card-overlay {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      background: linear-gradient(transparent, rgba(0,0,0,.85));
      padding: 2rem 0.75rem 0.75rem;
    }
    .img-card-title { font-size: 0.8rem; font-weight: 600; line-height: 1.3; }
    .img-card-title a { color: #fff; text-decoration: none; }

    .empty { color: var(--muted); font-size: 0.9rem; padding: 1.5rem 0; }

    @media (max-width: 640px) {
      .cards-grid { grid-template-columns: 1fr; }
      header { flex-direction: column; align-items: flex-start; }
      .search-bar { max-width: 100%; }
    }
  </style>
</head>
<body>

{# ── CARD MACRO — must be defined before first use ──────────────────────── #}
{% macro render_card(item, show_top_badge=False) %}
<article class="card" data-title="{{ item.title | lower }}" data-source="{{ item.source_id | lower }}" data-topic="{{ (item.topic or '') | lower }}">
  {% if item.preview_image_url %}
  <img class="card-image" src="{{ item.preview_image_url }}" alt="{{ item.title }}" loading="lazy"
       onerror="this.style.display='none'">
  {% endif %}

  <div class="card-body">
    <div class="card-meta">
      {% if show_top_badge %}<span class="badge badge-top">★ Top</span>{% endif %}
      <span class="badge badge-source">{{ item.source_id }}</span>
      {% if item.topic %}<span class="badge badge-topic">{{ item.topic }}</span>{% endif %}
      <span class="card-date">{{ item.published_at | fmt_date if item.published_at else "–" }}</span>
    </div>

    <h3 class="card-title">
      <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer">{{ item.title }}</a>
    </h3>

    {% set display_text = item.annotation or item.content_snippet %}
    {% if display_text %}
    <p class="card-annotation">{{ display_text | truncate(280) }}</p>
    {% endif %}

    {% if item.why_it_matters %}
    <p class="card-why">{{ item.why_it_matters }}</p>
    {% endif %}

    {% set all_tags = (item.tags_json | from_json) if item.tags_json else [] %}
    {% if all_tags %}
    <div class="card-tags">
      {% for tag in all_tags[:6] %}
      <span class="tag">{{ tag }}</span>
      {% endfor %}
    </div>
    {% endif %}
  </div>

  <div class="card-footer">
    <a class="card-link" href="{{ item.url }}" target="_blank" rel="noopener noreferrer">Read →</a>
    {% if item.priority_score %}
    <span class="score {% if item.priority_score >= 75 %}score-high{% elif item.priority_score >= 45 %}score-mid{% else %}score-low{% endif %}">
      {{ item.priority_score }}/100
    </span>
    {% endif %}
  </div>
</article>
{% endmacro %}

<header>
  <div>
    <div class="site-title">AI <span>News</span></div>
    <div class="meta">Generated {{ generated_at }} · {{ total_items }} items</div>
  </div>
  <div class="search-bar">
    <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;color:#8b8fa8">
      <circle cx="8" cy="8" r="6"/><line x1="13" y1="13" x2="18" y2="18"/>
    </svg>
    <input id="search-input" type="search" placeholder="Filter articles…" autocomplete="off">
  </div>
</header>

<div class="wrapper">

  {# ── TOP STORIES ──────────────────────────────────────────── #}
  {% if top_stories %}
  <section class="section" data-section="top_stories">
    <div class="section-header">
      <h2 class="section-title">⭐ Top Stories</h2>
      <span class="section-count">{{ top_stories | length }}</span>
    </div>
    <div class="cards-grid">
      {% for item in top_stories %}
      {{ render_card(item, show_top_badge=True) }}
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {# ── LATEST ITEMS ─────────────────────────────────────────── #}
  {% if latest_items %}
  <section class="section" data-section="latest">
    <div class="section-header">
      <h2 class="section-title">🕑 Latest</h2>
      <span class="section-count">{{ latest_items | length }}</span>
    </div>
    <div class="cards-grid">
      {% for item in latest_items %}
      {{ render_card(item) }}
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {# ── BY SOURCE ────────────────────────────────────────────── #}
  {% if by_source %}
  <section class="section" data-section="by_source">
    <div class="section-header">
      <h2 class="section-title">📡 By Source</h2>
    </div>
    {% for source_name, source_items in by_source.items() %}
    <div class="source-group">
      <div class="source-group-title">{{ source_name }} ({{ source_items | length }})</div>
      <ul class="source-list">
        {% for item in source_items %}
        <li>
          <span class="source-date">{{ item.published_at | fmt_date if item.published_at else "–" }}</span>
          <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer" data-title="{{ item.title | lower }}">{{ item.title }}</a>
        </li>
        {% endfor %}
      </ul>
    </div>
    {% endfor %}
  </section>
  {% endif %}

  {# ── IMAGE HIGHLIGHTS ─────────────────────────────────────── #}
  {% if image_highlights %}
  <section class="section" data-section="image_highlights">
    <div class="section-header">
      <h2 class="section-title">🖼 Image Highlights</h2>
      <span class="section-count">{{ image_highlights | length }}</span>
    </div>
    <div class="image-grid">
      {% for item in image_highlights %}
      <div class="img-card">
        <img src="{{ item.preview_image_url }}" alt="{{ item.title }}" loading="lazy" onerror="this.closest('.img-card').style.display='none'">
        <div class="img-card-overlay">
          <div class="img-card-title">
            <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer">{{ item.title }}</a>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {% if not top_stories and not latest_items %}
  <div class="empty">No items to display. Run the pipeline to collect news.</div>
  {% endif %}

</div>

<script>
(function () {
  "use strict";
  const input = document.getElementById("search-input");
  if (!input) return;

  function debounce(fn, ms) {
    let timer;
    return function (...args) { clearTimeout(timer); timer = setTimeout(() => fn.apply(this, args), ms); };
  }

  function filterCards(query) {
    const q = query.toLowerCase().trim();
    const cards = document.querySelectorAll(".card, .source-list li");
    cards.forEach(el => {
      const title = (el.dataset.title || el.querySelector("a")?.textContent || "").toLowerCase();
      const source = (el.dataset.source || "").toLowerCase();
      const topic = (el.dataset.topic || "").toLowerCase();
      const match = !q || title.includes(q) || source.includes(q) || topic.includes(q);
      el.style.display = match ? "" : "none";
    });

    document.querySelectorAll(".section").forEach(section => {
      const visible = section.querySelectorAll(".card:not([style*='display: none']), .source-list li:not([style*='display: none'])");
      section.style.display = visible.length === 0 && q ? "none" : "";
    });
  }

  input.addEventListener("input", debounce(e => filterCards(e.target.value), 150));
})();
</script>
</body>
</html>
